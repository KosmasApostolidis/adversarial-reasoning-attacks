# HuggingFace
HF_TOKEN=                           # required for gated models (Llama-3.2-Vision)
HF_HOME=./.hf_cache                 # move cache off home partition if needed
HF_HUB_ENABLE_HF_TRANSFER=1

# Ollama
OLLAMA_HOST=http://127.0.0.1:11434

# CUDA
CUDA_VISIBLE_DEVICES=0

# Reproducibility
PYTHONHASHSEED=0
TOKENIZERS_PARALLELISM=false

# Optional: WandB / MLflow (disable by default; record to local JSONL only)
WANDB_MODE=disabled
